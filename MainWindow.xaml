<Window x:Class="FightingTournament.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FightingTournament.ViewModels"
        Title="Fighting Tournament Tracker"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBg}"
        Foreground="{StaticResource BrushText}"
        WindowStyle="SingleBorderWindow">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- The ContentControl resolves DataTemplates from App.xaml -->
    <ContentControl Content="{Binding CurrentView}"
                    Focusable="False"/>
</Window>
