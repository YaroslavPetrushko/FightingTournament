<Application x:Class="FightingTournament.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FightingTournament.ViewModels"
             xmlns:views="clr-namespace:FightingTournament.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Fallback static colors for dynamic theme resources -->
        <Color x:Key="ColorBg">#0D0D15</Color>
        <Color x:Key="ColorAccent">#E8003D</Color>

        <!-- ═══════════════════════════════════════════════════════════
             PALETTE
        ═════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BrushBg"          Color="#0D0D15"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#16161F"/>
        <SolidColorBrush x:Key="BrushSurface2"    Color="#1E1E2A"/>
        <SolidColorBrush x:Key="BrushSurface3"    Color="#26263A"/>
        <SolidColorBrush x:Key="BrushAccent"      Color="#E8003D"/>
        <SolidColorBrush x:Key="BrushAccentDim"   Color="#8C0025"/>
        <SolidColorBrush x:Key="BrushAccentHover" Color="#FF1A54"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E8E8F2"/>
        <SolidColorBrush x:Key="BrushTextDim"     Color="#7070A0"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BrushBorderLight" Color="#3A3A52"/>
        <SolidColorBrush x:Key="BrushWin"         Color="#00CC6A"/>
        <SolidColorBrush x:Key="BrushLoss"        Color="#FF4444"/>
        <SolidColorBrush x:Key="BrushCurrent"     Color="#FF9800"/>
        <SolidColorBrush x:Key="BrushElim"        Color="#26161B"/>

        <!-- ═══════════════════════════════════════════════════════════
             TYPOGRAPHY
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{DynamicResource BrushText}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             SCROLLBAR (slim dark)
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource BrushSurface}"/>
            <Setter Property="Width"      Value="6"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             TOOLTIP
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="ToolTip">
            <Setter Property="Background"      Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"      Value="{DynamicResource BrushText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BrushBorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="HasDropShadow"   Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- ═══════════════════════════════════════════════════════════
             BUTTON — primary
        ═════════════════════════════════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="{DynamicResource BrushAccent}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BrushAccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{DynamicResource BrushSurface3}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushTextDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ghost button (dim outline) -->
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource BrushTextDim}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BrushBorderLight}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource BrushText}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- small square counter button -->
        <Style x:Key="BtnCounter" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Width"   Value="32"/>
            <Setter Property="Height"  Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <!-- tiny eliminate × -->
        <Style x:Key="BtnElim" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
            <Setter Property="Width"      Value="20"/>
            <Setter Property="Height"     Value="20"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="ToolTip"    Value="Eliminate player"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent"
                                CornerRadius="2" Padding="0">
                            <TextBlock x:Name="Lbl" Text="✕"
                                       FontSize="11"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground"
                                        Value="{DynamicResource BrushLoss}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Lbl" Property="Foreground"
                                        Value="{DynamicResource BrushSurface3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             TEXTBOX
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"       Value="{DynamicResource BrushText}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="CaretBrush"       Value="{DynamicResource BrushAccent}"/>
            <Setter Property="SelectionBrush"   Value="{DynamicResource BrushAccentDim}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             COMBOBOX
        ═════════════════════════════════════════════════════════════ -->
        <!-- Item inside the drop-down popup -->
        <Style x:Key="ComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"  Value="{DynamicResource BrushText}"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource BrushSurface3}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{DynamicResource BrushAccentDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ToggleButton inside ComboBox template -->
        <Style x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                </Grid.ColumnDefinitions>
                                <!-- Arrow -->
                                <Border Grid.Column="1" Background="Transparent" VerticalAlignment="Stretch">
                                    <TextBlock Text="▾"
                                               FontSize="10"
                                               Foreground="{DynamicResource BrushTextDim}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"         Value="{DynamicResource BrushSurface2}"/>
            <Setter Property="Foreground"         Value="{DynamicResource BrushText}"/>
            <Setter Property="BorderBrush"        Value="{DynamicResource BrushBorder}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="Height"             Value="30"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- The ToggleButton background -->
                            <ToggleButton x:Name="ToggleButton"
                                          Style="{StaticResource ComboBoxToggleButton}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"/>

                            <!-- Main content area -->
                            <Grid Margin="1,1,23,1">
                                <!-- Editable TextBox -->
                                <TextBox x:Name="PART_EditableTextBox"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         Foreground="{DynamicResource BrushText}"
                                         BorderThickness="0"
                                         Padding="6,0,0,0"
                                         CaretBrush="{DynamicResource BrushAccent}"
                                         SelectionBrush="{DynamicResource BrushAccentDim}"
                                         FontFamily="Segoe UI"
                                         FontSize="12"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Visibility="Collapsed"/>

                                <!-- Read-only content site -->
                                <ContentPresenter x:Name="ContentSite"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  IsHitTestVisible="False"/>
                            </Grid>

                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource BrushSurface2}"
                                        BorderBrush="{DynamicResource BrushBorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Switch to editable mode -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite"          Property="Visibility" Value="Collapsed"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Trigger>
                            <!-- Focus ring -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush"
                                        Value="{DynamicResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             RADIOBUTTON  (custom WIN pill)
        ═════════════════════════════════════════════════════════════ -->
        <Style x:Key="RadioWin" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Pill"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BrushBorderLight}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="10,4"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill"  Property="BorderBrush"
                                        Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             SEPARATOR
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="Separator">
            <Setter Property="Background"  Value="{DynamicResource BrushBorder}"/>
            <Setter Property="Height"      Value="1"/>
            <Setter Property="Margin"      Value="0,4"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             MENU SYSTEM
        ═════════════════════════════════════════════════════════════ -->
        <Style x:Key="MenuSeparator" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="2,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuItem" TargetType="MenuItem">
            <Style.Resources>
                <!-- Inner sub-items styling inside dropdown panel -->
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="MenuItem">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="2" Margin="1,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" SharedSizeGroup="Icon"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20" SharedSizeGroup="Shortcut"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Column 0: Icon / Checkmark -->
                                        <Grid Grid.Column="0" Margin="2,0">
                                            <ContentPresenter x:Name="Icon" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Icon"/>
                                            <TextBlock x:Name="CheckMark" Text="✓" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed" FontSize="11" FontWeight="Bold"/>
                                        </Grid>
                                        
                                        <!-- Column 1: Header content -->
                                        <ContentPresenter Grid.Column="1" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" ContentSource="Header" VerticalAlignment="Center"/>
                                        
                                        <!-- Column 2: Shortcut / Submenu Arrow -->
                                        <Grid Grid.Column="2" Margin="4,0,0,0">
                                            <Path x:Name="Arrow" Data="M0,0 L4,4 L0,8" Stroke="{DynamicResource BrushTextDim}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                        </Grid>

                                        <!-- Popup for nested submenus -->
                                        <Popup x:Name="SubMenuPopup" Placement="Right" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                            <Border Background="{DynamicResource BrushSurface2}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="4" CornerRadius="4" Margin="3,0,0,0">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.4" ShadowDepth="3"/>
                                                </Border.Effect>
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                            </Border>
                                        </Popup>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushAccentDim}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="Role" Value="SubmenuHeader">
                                        <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                        <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
            
            <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="1" CornerRadius="3">
                            <Grid>
                                <ContentPresenter ContentSource="Header" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" VerticalAlignment="Center"/>
                                
                                <Popup x:Name="SubMenuPopup" Placement="Bottom" IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <!-- Dropdown Menu panel -->
                                    <Border Background="{DynamicResource BrushSurface2}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="4" CornerRadius="4" Margin="0,3,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="10" Color="Black" Opacity="0.4" ShadowDepth="3"/>
                                        </Border.Effect>
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushSurface2}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource BrushSurface2}"/>
                                <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource BrushBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             MVVM NAVIGATION — DataTemplates
        ═════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:SetupViewModel}">
            <views:SetupView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TournamentViewModel}">
            <views:TournamentView/>
        </DataTemplate>

    </Application.Resources>
</Application>
