<Application x:Class="FightingTournament.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FightingTournament.ViewModels"
             xmlns:views="clr-namespace:FightingTournament.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ═══════════════════════════════════════════════════════════
             PALETTE
        ═════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="BrushBg"          Color="#0D0D15"/>
        <SolidColorBrush x:Key="BrushSurface"     Color="#16161F"/>
        <SolidColorBrush x:Key="BrushSurface2"    Color="#1E1E2A"/>
        <SolidColorBrush x:Key="BrushSurface3"    Color="#26263A"/>
        <SolidColorBrush x:Key="BrushAccent"      Color="#E8003D"/>
        <SolidColorBrush x:Key="BrushAccentDim"   Color="#8C0025"/>
        <SolidColorBrush x:Key="BrushAccentHover" Color="#FF1A54"/>
        <SolidColorBrush x:Key="BrushText"        Color="#E8E8F2"/>
        <SolidColorBrush x:Key="BrushTextDim"     Color="#7070A0"/>
        <SolidColorBrush x:Key="BrushBorder"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BrushBorderLight" Color="#3A3A52"/>
        <SolidColorBrush x:Key="BrushWin"         Color="#00CC6A"/>
        <SolidColorBrush x:Key="BrushLoss"        Color="#FF4444"/>
        <SolidColorBrush x:Key="BrushCurrent"     Color="#FF9800"/>
        <SolidColorBrush x:Key="BrushElim"        Color="#3A1A1A"/>

        <!-- ═══════════════════════════════════════════════════════════
             TYPOGRAPHY BASE
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             BUTTON — primary
        ═════════════════════════════════════════════════════════════ -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource BrushAccent}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="20,10"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource BrushAccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource BrushAccentDim}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource BrushSurface3}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource BrushTextDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ghost -->
        <Style x:Key="BtnGhost" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextDim}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent"
                                BorderBrush="{StaticResource BrushBorderLight}"
                                BorderThickness="1" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush"
                                        Value="{StaticResource BrushAccent}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource BrushText}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                        Value="{StaticResource BrushSurface3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- small ± counter -->
        <Style x:Key="BtnCounter" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Width"    Value="32"/>
            <Setter Property="Height"   Value="32"/>
            <Setter Property="Padding"  Value="0"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <!-- tiny eliminate × -->
        <Style x:Key="BtnElim" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextDim}"/>
            <Setter Property="Width"      Value="20"/>
            <Setter Property="Height"     Value="20"/>
            <Setter Property="Padding"    Value="0"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="ToolTip"    Value="Eliminate player"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent"
                                CornerRadius="2" Padding="0">
                            <TextBlock x:Name="Lbl" Text="✕"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Lbl" Property="Foreground"
                                        Value="{StaticResource BrushLoss}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Lbl" Property="Foreground"
                                        Value="{StaticResource BrushSurface3}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             TEXTBOX
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BrushSurface2}"/>
            <Setter Property="Foreground"      Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,6"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="{StaticResource BrushAccent}"/>
            <Setter Property="SelectionBrush"  Value="{StaticResource BrushAccentDim}"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             COMBOBOX — full dark ControlTemplate
        ═════════════════════════════════════════════════════════════ -->

        <!-- Item inside the drop-down popup -->
        <Style x:Key="ComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background"  Value="{StaticResource BrushSurface2}"/>
            <Setter Property="Foreground"  Value="{StaticResource BrushText}"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource BrushSurface3}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource BrushAccentDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"         Value="{StaticResource BrushSurface2}"/>
            <Setter Property="Foreground"         Value="{StaticResource BrushText}"/>
            <Setter Property="BorderBrush"        Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness"    Value="1"/>
            <Setter Property="FontFamily"         Value="Segoe UI"/>
            <Setter Property="FontSize"           Value="12"/>
            <Setter Property="Height"             Value="30"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Main border / text area -->
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Editable TextBox or read-only presenter -->
                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="6,0,0,0"
                                             VerticalAlignment="Center"
                                             Background="Transparent"
                                             Foreground="{StaticResource BrushText}"
                                             BorderThickness="0"
                                             CaretBrush="{StaticResource BrushAccent}"
                                             SelectionBrush="{StaticResource BrushAccentDim}"
                                             FontFamily="Segoe UI"
                                             FontSize="12"
                                             IsReadOnly="{TemplateBinding IsReadOnly}"
                                             Visibility="Collapsed"/>

                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Margin="8,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                                    <!-- Drop arrow -->
                                    <Border Grid.Column="1" VerticalAlignment="Stretch">
                                        <TextBlock Text="▾"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrushTextDim}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Popup -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource BrushSurface2}"
                                        BorderBrush="{StaticResource BrushBorderLight}"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="220"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Switch to editable mode -->
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="ContentSite"          Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Focus ring -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{StaticResource BrushAccent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             RADIOBUTTON — WIN pill
        ═════════════════════════════════════════════════════════════ -->
        <Style x:Key="RadioWin" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Pill"
                                BorderBrush="{StaticResource BrushBorderLight}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="10,4"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontFamily="Segoe UI"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrushTextDim}"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill"  Property="Background"   Value="{StaticResource BrushAccent}"/>
                                <Setter TargetName="Pill"  Property="BorderBrush"  Value="{StaticResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground"   Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="{StaticResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             SEPARATOR
        ═════════════════════════════════════════════════════════════ -->
        <Style TargetType="Separator">
            <Setter Property="Background" Value="{StaticResource BrushBorder}"/>
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="0,4"/>
        </Style>

        <!-- ═══════════════════════════════════════════════════════════
             MVVM DataTemplates
        ═════════════════════════════════════════════════════════════ -->
        <DataTemplate DataType="{x:Type vm:SetupViewModel}">
            <views:SetupView/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TournamentViewModel}">
            <views:TournamentView/>
        </DataTemplate>

    </Application.Resources>
</Application>
