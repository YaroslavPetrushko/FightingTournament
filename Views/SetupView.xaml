<UserControl x:Class="FightingTournament.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FightingTournament.Converters"
             Background="{StaticResource BrushBg}">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title / Logo / Errors -->
            <RowDefinition Height="*"/>    <!-- Main Cards -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Title & Validation ── -->
        <StackPanel Grid.Row="0" Margin="0,35,0,15">
            <TextBlock Text="⚔"
                       FontSize="38"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="FIGHTING TOURNAMENT"
                       FontSize="24"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="TRACKER"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushAccent}"
                       Margin="0,2,0,0"/>

            <!-- Global Validation Message -->
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{StaticResource BrushLoss}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       Visibility="{Binding ValidationMessage,
                                    Converter={StaticResource StrVis}}"/>
        </StackPanel>

        <!-- ── Row 1: Dashboard Panels ── -->
        <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/> <!-- Left: Create -->
                <ColumnDefinition Width="30"/>  <!-- Gap 1 -->
                <ColumnDefinition Width="320"/> <!-- Center: Resume -->
                <ColumnDefinition Width="30"/>  <!-- Gap 2 -->
                <ColumnDefinition Width="260"/> <!-- Right: Registered Players -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT CARD: Create New Tournament ── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="28,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="CREATE NEW TOURNAMENT"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Session Name row -->
                    <TextBlock Text="SESSION NAME"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,18"/>

                    <!-- Game selection row -->
                    <TextBlock Text="SELECT GAME"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableGames}"
                              SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                              Margin="0,0,0,18"/>

                    <!-- Player count row -->
                    <TextBlock Text="NUMBER OF PLAYERS"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="−"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding DecrementCommand}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PlayerCount}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushText}"/>
                        <Button Grid.Column="3"
                                Content="+"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding IncrementCommand}"/>
                    </Grid>

                    <!-- Player names label -->
                    <TextBlock Text="PLAYER NAMES"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="145"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,20">
                        <ItemsControl ItemsSource="{Binding PlayerEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextDim}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Start button -->
                    <Button Content="START TOURNAMENT"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="13"
                            Padding="0,11"
                            Command="{Binding StartCommand}"/>
                </StackPanel>
            </Border>

            <!-- ── CENTER CARD: Resume Saved Session ── -->
            <Border Grid.Column="3"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="24,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="RESUME SAVED SESSION"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Saved Sessions Dropdown -->
                    <TextBlock Text="SELECT SAVED SESSION"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding SavedSessions}"
                              SelectedItem="{Binding SelectedSavedSession, Mode=TwoWay}"
                              Margin="0,0,0,24"/>

                    <!-- Action buttons -->
                    <Button Content="RESUME TOURNAMENT  ►"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="13"
                            Padding="0,11"
                            Margin="0,0,0,12"
                            Command="{Binding ResumeCommand}"/>

                    <Button Content="DELETE SESSION  ✗"
                            Style="{StaticResource BtnGhost}"
                            FontSize="11"
                            Padding="0,9"
                            Command="{Binding DeleteSessionCommand}"/>
                </StackPanel>
            </Border>

            <!-- ── RIGHT SIDEBAR: Registered Players ── -->
            <Border Grid.Column="5"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="REGISTERED PLAYERS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,4"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="CLICK TO QUICK-ADD TO SETUP"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,16"
                               HorizontalAlignment="Center"/>

                    <!-- Scrollable List of players -->
                    <ScrollViewer MaxHeight="245"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,0">
                        <ItemsControl ItemsSource="{Binding RegisteredUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AddPlayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,0,6"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder"
                                                        Background="{StaticResource BrushSurface2}"
                                                        BorderBrush="{StaticResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="12"
                                                               FontWeight="Medium"
                                                               Foreground="{StaticResource BrushText}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource BrushSurface3}"/>
                                                        <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placeholder text when empty using standard WPF logic -->
                    <TextBlock Text="No players registered yet. They will appear here after starting your first tournament."
                               FontSize="11"
                               Foreground="{StaticResource BrushTextDim}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,15,0,5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RegisteredUsers.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Row 2: Footer ── -->
        <TextBlock Grid.Row="2"
                   Text="Round-robin · all vs all · circle algorithm"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource BrushTextDim}"
                   Margin="0,0,0,20"/>
    </Grid>
</UserControl>
