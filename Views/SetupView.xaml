<UserControl x:Class="FightingTournament.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FightingTournament.Converters"
             Background="{StaticResource BrushBg}">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="0,40">

            <!-- ── Logo / Title ── -->
            <StackPanel Margin="0,0,0,40">
                <TextBlock Text="⚔"
                           FontSize="40"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="FIGHTING TOURNAMENT"
                           FontSize="26"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrushText}"/>
                <TextBlock Text="TRACKER"
                           FontSize="14"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource BrushAccent}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- ── Surface card ── -->
            <Border Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="32,28">
                <StackPanel>

                    <!-- Game selection row -->
                    <TextBlock Text="SELECT GAME"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,10"/>

                    <ComboBox ItemsSource="{Binding AvailableGames}"
                              SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                              Margin="0,0,0,24"/>

                    <!-- Player count row -->
                    <TextBlock Text="NUMBER OF PLAYERS"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="−"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding DecrementCommand}"/>

                        <TextBlock Grid.Column="2"
                                   Text="{Binding PlayerCount}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushText}"/>

                        <Button Grid.Column="3"
                                Content="+"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding IncrementCommand}"/>
                    </Grid>

                    <!-- Player names label -->
                    <TextBlock Text="PLAYER NAMES"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,10"/>

                    <!-- Scrollable name list -->
                    <ScrollViewer MaxHeight="260"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,24">
                        <ItemsControl ItemsSource="{Binding PlayerEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{StaticResource BrushTextDim}"/>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Validation message -->
                    <TextBlock Text="{Binding ValidationMessage}"
                               Foreground="{StaticResource BrushLoss}"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"
                               Visibility="{Binding ValidationMessage,
                                            Converter={StaticResource StrVis}}"/>

                    <!-- Start button -->
                    <Button Content="START TOURNAMENT"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="14"
                            Padding="0,14"
                            Command="{Binding StartCommand}"/>

                </StackPanel>
            </Border>

            <!-- Sub-caption -->
            <TextBlock Text="Round-robin · all vs all · circle algorithm"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushTextDim}"
                       Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
