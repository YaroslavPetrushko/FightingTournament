<UserControl x:Class="FightingTournament.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FightingTournament.Converters"
             Background="{StaticResource BrushBg}">

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title / Logo / Errors -->
            <RowDefinition Height="*"/>    <!-- Main Cards -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Title & Validation ── -->
        <StackPanel Grid.Row="0" Margin="0,35,0,15">
            <TextBlock Text="⚔"
                       FontSize="38"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4"/>
            <TextBlock Text="FIGHTING TOURNAMENT"
                       FontSize="24"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="TRACKER"
                       FontSize="13"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource BrushAccent}"
                       Margin="0,2,0,0"/>

            <!-- Global Validation Message -->
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{StaticResource BrushLoss}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       Visibility="{Binding ValidationMessage,
                                    Converter={StaticResource StrVis}}"/>
        </StackPanel>

        <!-- ── Row 1: Side-by-Side Cards ── -->
        <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/> <!-- Left: Create -->
                <ColumnDefinition Width="40"/>  <!-- Gap -->
                <ColumnDefinition Width="400"/> <!-- Right: Resume -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT CARD: Create New Tournament ── -->
            <Border Grid.Column="1"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="28,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="CREATE NEW TOURNAMENT"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Session Name row -->
                    <TextBlock Text="SESSION NAME"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,18"/>

                    <!-- Game selection row -->
                    <TextBlock Text="SELECT GAME"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableGames}"
                              SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                              Margin="0,0,0,18"/>

                    <!-- Player count row -->
                    <TextBlock Text="NUMBER OF PLAYERS"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="1"
                                Content="−"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding DecrementCommand}"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding PlayerCount}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BrushText}"/>
                        <Button Grid.Column="3"
                                Content="+"
                                Style="{StaticResource BtnCounter}"
                                Command="{Binding IncrementCommand}"/>
                    </Grid>

                    <!-- Player names label -->
                    <TextBlock Text="PLAYER NAMES"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ScrollViewer MaxHeight="145"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,20">
                        <ItemsControl ItemsSource="{Binding PlayerEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   VerticalAlignment="Center"
                                                   FontSize="11"
                                                   Foreground="{StaticResource BrushTextDim}"/>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Start button -->
                    <Button Content="START TOURNAMENT"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="13"
                            Padding="0,11"
                            Command="{Binding StartCommand}"/>
                </StackPanel>
            </Border>

            <!-- ── RIGHT CARD: Resume Saved Session ── -->
            <Border Grid.Column="3"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="28,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="RESUME SAVED SESSION"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"/>

                    <!-- Saved Sessions Dropdown -->
                    <TextBlock Text="SELECT SAVED SESSION"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextDim}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding SavedSessions}"
                              SelectedItem="{Binding SelectedSavedSession, Mode=TwoWay}"
                              Margin="0,0,0,24"/>

                    <!-- Action buttons -->
                    <Button Content="RESUME TOURNAMENT  ►"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="13"
                            Padding="0,11"
                            Margin="0,0,0,12"
                            Command="{Binding ResumeCommand}"/>

                    <Button Content="DELETE SESSION  ✗"
                            Style="{StaticResource BtnGhost}"
                            FontSize="11"
                            Padding="0,9"
                            Command="{Binding DeleteSessionCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Row 2: Footer ── -->
        <TextBlock Grid.Row="2"
                   Text="Round-robin · all vs all · circle algorithm"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource BrushTextDim}"
                   Margin="0,0,0,20"/>
    </Grid>
</UserControl>
