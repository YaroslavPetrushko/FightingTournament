<UserControl x:Class="FightingTournament.Views.SetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FightingTournament.Converters"
             Background="Transparent">

    <UserControl.RenderTransform>
        <TranslateTransform Y="20"/>
    </UserControl.RenderTransform>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <EventTrigger RoutedEvent="UserControl.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UserControl.RenderTransform).(TranslateTransform.Y)"
                                             From="20" To="0" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>

        <!-- Segmented button left style -->
        <Style x:Key="RadioModeLeftBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BtnBorder"
                                Background="{DynamicResource BrushSurface2}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="4,0,0,4"
                                Padding="10,8"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BrushAccentDim}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented button right style -->
        <Style x:Key="RadioModeRightBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BtnBorder"
                                Background="{DynamicResource BrushSurface2}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,4,4,0"
                                Padding="10,8"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BrushAccentDim}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title / Logo / Errors -->
            <RowDefinition Height="*"/>    <!-- Main Cards -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Title & Validation ── -->
        <StackPanel Grid.Row="0" Margin="0,22,0,8">
            <TextBlock FontSize="18"
                       FontWeight="Bold"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <Run Text="⚔  FIGHTING TOURNAMENT " Foreground="{DynamicResource BrushText}"/>
                <Run Text="TRACKER" Foreground="{DynamicResource BrushAccent}"/>
            </TextBlock>

            <!-- Global Validation Message -->
            <TextBlock Text="{Binding ValidationMessage}"
                       Foreground="{DynamicResource BrushLoss}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       Visibility="{Binding ValidationMessage,
                                    Converter={StaticResource StrVis}}"/>
        </StackPanel>

        <!-- ── Row 1: Dashboard Panels ── -->
        <Grid Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/> <!-- Left: Create -->
                <ColumnDefinition Width="30"/>  <!-- Gap 1 -->
                <ColumnDefinition Width="320"/> <!-- Center: Resume -->
                <ColumnDefinition Width="30"/>  <!-- Gap 2 -->
                <ColumnDefinition Width="260"/> <!-- Right: Registered Players -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT CARD: Create New Tournament ── -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="24,20"
                    VerticalAlignment="Stretch"
                    MaxHeight="800">
                <DockPanel>
                    <TextBlock Text="CREATE NEW TOURNAMENT"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushAccent}"
                               Margin="0,0,0,15"
                               HorizontalAlignment="Center"
                               DockPanel.Dock="Top"/>

                    <!-- Start button pinned at the bottom -->
                    <Button Content="START TOURNAMENT"
                            Style="{StaticResource BtnPrimary}"
                            FontSize="13"
                            Padding="0,11"
                            Command="{Binding StartCommand}"
                            DockPanel.Dock="Bottom"
                            Margin="0,10,0,0"/>

                    <!-- Scrollable Inner Form -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,0,8,0">
                            <!-- Session Name row -->
                            <TextBlock Text="SESSION NAME"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <TextBox Text="{Binding SessionName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,18"/>

                            <!-- Game selection row -->
                            <TextBlock Text="SELECT GAME"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AvailableGames}"
                                      SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                                      Text="{Binding SelectedGame, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                      IsEditable="True"
                                      Margin="0,0,0,18"/>

                            <!-- Default Rounds row -->
                            <TextBlock Text="DEFAULT ROUNDS"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AvailableRoundsList}"
                                      SelectedItem="{Binding SelectedRounds, Mode=TwoWay}"
                                      Margin="0,0,0,18"/>

                            <!-- Tournament Mode Row -->
                            <TextBlock Text="TOURNAMENT MODE"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,18" Height="34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Column="0"
                                             Content="ENDLESS RUN"
                                             Style="{StaticResource RadioModeLeftBtn}"
                                             GroupName="ModeGroup"
                                             IsChecked="{Binding IsEndlessModeSelected, Mode=TwoWay}"/>
                                <RadioButton Grid.Column="1"
                                             Content="CHAMPIONSHIP"
                                             Style="{StaticResource RadioModeRightBtn}"
                                             GroupName="ModeGroup"
                                             IsChecked="{Binding IsChampionshipModeSelected, Mode=TwoWay}"/>
                            </Grid>

                            <!-- Player count row -->
                            <TextBlock Text="NUMBER OF PLAYERS"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="1"
                                        Content="−"
                                        Style="{StaticResource BtnCounter}"
                                        Command="{Binding DecrementCommand}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding PlayerCount}"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource BrushText}"/>
                                <Button Grid.Column="3"
                                        Content="+"
                                        Style="{StaticResource BtnCounter}"
                                        Command="{Binding IncrementCommand}"/>
                            </Grid>

                            <!-- Player names label -->
                            <TextBlock Text="PLAYER NAMES"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding PlayerEntries}" Margin="0,0,0,10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Index}"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource BrushTextDim}"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- ── CENTER CARD: Resume Saved Session & Presets ── -->
            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                <!-- Resume Card -->
                <Border Background="{DynamicResource BrushSurface}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="24,24"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="RESUME SAVED SESSION"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushAccent}"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <!-- Saved Sessions Dropdown -->
                        <TextBlock Text="SELECT SAVED SESSION"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextDim}"
                                   Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding SavedSessions}"
                                  SelectedItem="{Binding SelectedSavedSession, Mode=TwoWay}"
                                  Margin="0,0,0,24"/>

                        <!-- Action buttons -->
                        <Button Content="RESUME TOURNAMENT  ►"
                                Style="{StaticResource BtnPrimary}"
                                FontSize="13"
                                Padding="0,11"
                                Margin="0,0,0,12"
                                Command="{Binding ResumeCommand}"/>

                        <Button Content="DELETE SESSION  ✗"
                                Style="{StaticResource BtnGhost}"
                                FontSize="11"
                                Padding="0,9"
                                Command="{Binding DeleteSessionCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Presets Card -->
                <Border Background="{DynamicResource BrushSurface}"
                        BorderBrush="{DynamicResource BrushBorder}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="24,24">
                    <StackPanel>
                        <TextBlock Text="SAVED PRESETS"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrushAccent}"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="LOAD SAVED PRESET"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextDim}"
                                   Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding UserPresets}"
                                      SelectedItem="{Binding SelectedUserPreset, Mode=TwoWay}"
                                      DisplayMemberPath="PresetName"
                                      VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Delete"
                                    Style="{StaticResource BtnGhost}"
                                    Width="60"
                                    Margin="8,0,0,0"
                                    Padding="0,6"
                                    Command="{Binding DeletePresetCommand}"/>
                        </Grid>

                        <TextBlock Text="SAVE CURRENT SETUP AS PRESET"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextDim}"
                                   Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Content="Save"
                                    Style="{StaticResource BtnGhost}"
                                    Width="60"
                                    Margin="8,0,0,0"
                                    Padding="0,6"
                                    Command="{Binding SavePresetCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── RIGHT SIDEBAR: Registered Players ── -->
            <Border Grid.Column="5"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20,24"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="REGISTERED PLAYERS"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{DynamicResource BrushAccent}"
                               Margin="0,0,0,4"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="L-CLICK ADD | DBL-CLICK PROFILE"
                               FontSize="9"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextDim}"
                               Margin="0,0,0,16"
                               HorizontalAlignment="Center"/>

                    <!-- Scrollable List of players -->
                    <ScrollViewer MaxHeight="265"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,0">
                        <ItemsControl ItemsSource="{Binding RegisteredUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AddPlayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,0,6"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Left"
                                            Cursor="Hand">
                                        <Button.InputBindings>
                                            <MouseBinding Gesture="RightClick"
                                                          Command="{Binding DataContext.DeleteRegisteredPlayerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                            <MouseBinding Gesture="LeftDoubleClick"
                                                          Command="{Binding DataContext.ShowUserProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Button.InputBindings>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="BtnBorder"
                                                        Background="{DynamicResource BrushSurface2}"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <TextBlock Text="{Binding}"
                                                               FontSize="12"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource BrushText}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BrushSurface3}"/>
                                                        <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placeholder text when empty using standard WPF logic -->
                    <TextBlock Text="No players registered yet. They will appear here after starting your first tournament."
                               FontSize="11"
                               Foreground="{DynamicResource BrushTextDim}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,15,0,5">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RegisteredUsers.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="Round-robin  ·  all-pairs per cycle  ·  endless or championship"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource BrushTextDim}"
                   Margin="0,0,0,20"/>
    </Grid>
</UserControl>
