<Window x:Class="FightingTournament.Views.UserProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Player Profile"
        Height="420" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        Foreground="{DynamicResource BrushText}"
        ResizeMode="NoResize"
        WindowStyle="None">

    <Border Background="{DynamicResource BrushBg}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1,0,1,1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="2"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentDim}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title / Icon -->
                <RowDefinition Height="*"/>    <!-- Stats Grid -->
                <RowDefinition Height="Auto"/> <!-- Actions Row -->
            </Grid.RowDefinitions>

            <!-- Gradients border on top of the window -->
            <Border Height="3" VerticalAlignment="Top" Margin="-20,-20,-20,0" Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{DynamicResource ColorBg}" Offset="0.0"/>
                        <GradientStop Color="{DynamicResource ColorAccent}" Offset="0.5"/>
                        <GradientStop Color="{DynamicResource ColorBg}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Icon & Title -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,15" x:Name="TitleArea" Background="Transparent" MouseDown="TitleArea_MouseDown">
                <TextBlock Text="👤" FontSize="36" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock x:Name="PlayerTitleText" Text="PLAYER PROFILE" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrushText}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="PlayerSubtitleText" Text="Global Tournament Statistics" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextDim}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Stats Dashboard Grid -->
            <Grid Grid.Row="1" Margin="10,0,10,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1" Background="{DynamicResource BrushSurface2}" BorderBrush="{DynamicResource BrushBorder}" BorderThickness="1" Padding="15,12" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Matches -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TOTAL MATCHES" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalMatches" Grid.Row="0" Grid.Column="1" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" VerticalAlignment="Center"/>

                        <!-- Total Wins -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TOTAL WINS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtTotalWins" Grid.Row="1" Grid.Column="1" Text="0" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" VerticalAlignment="Center"/>

                        <!-- Win Rate -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="WIN RATE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtWinRate" Grid.Row="2" Grid.Column="1" Text="0.0%" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrushWin}" VerticalAlignment="Center"/>

                        <!-- Favorite Character -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="FAVORITE CHARACTER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFavoriteCharacter" Grid.Row="3" Grid.Column="1" Text="None" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center"/>

                        <!-- Favorite Game -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="FAVORITE GAME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtFavoriteGame" Grid.Row="4" Grid.Column="1" Text="None" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" VerticalAlignment="Center"/>

                        <!-- Last Session Date -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="LAST PLAYED DATE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrushTextDim}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtLastMatchDate" Grid.Row="5" Grid.Column="1" Text="None" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Buttons Actions Row -->
            <DockPanel Grid.Row="2" LastChildFill="False">
                <!-- Left: Delete Button (Red) -->
                <Button x:Name="BtnDelete"
                        DockPanel.Dock="Left"
                        Content="DELETE USER"
                        Background="{DynamicResource BrushLoss}"
                        Style="{StaticResource BtnPrimary}"
                        Padding="16,8"
                        FontSize="11"
                        Click="BtnDelete_Click"/>

                <!-- Right: Close Button -->
                <Button DockPanel.Dock="Right"
                        Content="CLOSE"
                        Style="{StaticResource BtnPrimary}"
                        Padding="25,8"
                        FontSize="11"
                        Click="CloseButton_Click"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
