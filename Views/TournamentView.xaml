<UserControl x:Class="FightingTournament.Views.TournamentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FightingTournament.ViewModels"
             xmlns:conv="clr-namespace:FightingTournament.Converters"
             xmlns:models="clr-namespace:FightingTournament.Models"
             Background="Transparent">

    <UserControl.RenderTransform>
        <TranslateTransform Y="20"/>
    </UserControl.RenderTransform>

    <UserControl.Style>
        <Style TargetType="UserControl">
            <Style.Triggers>
                <EventTrigger RoutedEvent="UserControl.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UserControl.RenderTransform).(TranslateTransform.Y)"
                                             From="20" To="0" Duration="0:0:0.4">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolVis" Invert="True"/>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
        <conv:InverseBooleanConverter x:Key="InvBool"/>

        <!-- ── Column header label style ── -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
            <Setter Property="Margin"     Value="0,0,0,10"/>
        </Style>

        <!-- ── Standings cell ── -->
        <Style x:Key="StatCell" TargetType="TextBlock">
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="Foreground"          Value="{DynamicResource BrushText}"/>
            <Setter Property="VerticalAlignment"   Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <!-- ── Standings name cell ── -->
        <Style x:Key="StatName" TargetType="TextBlock" BasedOn="{StaticResource StatCell}">
            <Setter Property="FontFamily"          Value="Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextTrimming"        Value="CharacterEllipsis"/>
        </Style>

        <!-- Segmented toggle button left style -->
        <Style x:Key="RadioToggleLeftBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BtnBorder"
                                Background="{DynamicResource BrushSurface2}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="4,0,0,4"
                                Padding="14,6"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BrushSurface3}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented toggle button right style -->
        <Style x:Key="RadioToggleRightBtn" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="BtnBorder"
                                Background="{DynamicResource BrushSurface2}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="0,1,1,1"
                                CornerRadius="0,4,4,0"
                                Padding="14,6"
                                Cursor="Hand">
                            <TextBlock x:Name="Label"
                                       Text="{TemplateBinding Content}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrushTextDim}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource BrushSurface3}"/>
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccent}"/>
                                <Setter TargetName="Label" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{DynamicResource BrushAccentHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel>

        <!-- ══ TOP BAR ══════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource BrushSurface}"
                BorderBrush="{DynamicResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CycleHeader}"
                               FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource BrushCurrent}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="11" HorizontalAlignment="Center"
                               Foreground="{DynamicResource BrushTextDim}"
                               Visibility="{Binding StatusMessage, Converter={StaticResource StrVis}}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="New Tournament"
                        Style="{StaticResource BtnGhost}"
                        Padding="12,7" FontSize="11" Margin="0,0,10,0"
                        Command="{Binding NewTournamentCommand}"/>

                <Button Grid.Column="2" Content="{Binding SaveButtonText}"
                        Style="{StaticResource BtnPrimary}"
                        Padding="16,8" FontSize="12"
                        Command="{Binding CommitCycleCommand}"/>
            </Grid>
        </Border>

        <!-- ══ BODY (3 columns) ══════════════════════════════════════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="150"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"   MinWidth="480"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="290" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Schedule ────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="0,0,1,0"
                    Padding="14,18">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SCHEDULE"
                               Style="{StaticResource ColHeader}"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CycleSchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CycleInfoViewModel}">
                                    <Border Margin="0,0,0,4" Padding="8,7" CornerRadius="4" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.SelectCycleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource BrushSurface3}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <DockPanel LastChildFill="True" Margin="0,0,0,3">
                                                <!-- Status Glyph docked Left -->
                                                <TextBlock DockPanel.Dock="Left" Text="{Binding StatusGlyph}"
                                                           FontSize="10" Width="14" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrushWin}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrushCurrent}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <!-- Match Count docked Right -->
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding MatchCount}"
                                                           FontSize="9" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource BrushTextDim}"
                                                           HorizontalAlignment="Right"/>

                                                <!-- Cycle Name fills middle -->
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="2,0,0,0">
                                                    <TextBlock.Text>
                                                        <Binding Path="Number" StringFormat="Cycle {0}"/>
                                                    </TextBlock.Text>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource BrushText}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DockPanel>
                                            <!-- Match list (small) -->
                                            <TextBlock Text="{Binding Matchups}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource BrushTextDim}"
                                                       LineHeight="15"
                                                       Margin="14,0,0,0"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BrushBorder}" ShowsPreview="True"/>

            <!-- ── CENTER: Dashboard Panels ── -->
            <Border Grid.Column="2" Padding="22,18">
                <DockPanel>
                    
                    <!-- Toggle Buttons (Only visible in Championship mode) -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15"
                                Visibility="{Binding ShowBracketToggleVisible, Converter={StaticResource BoolVis}}">
                        <RadioButton Content="MATCH LIST" 
                                     Style="{StaticResource RadioToggleLeftBtn}"
                                     GroupName="ViewToggle"
                                     IsChecked="{Binding ShowBracket, Converter={StaticResource InvBool}, Mode=TwoWay}"/>
                        <RadioButton Content="BRACKET VIEW" 
                                     Style="{StaticResource RadioToggleRightBtn}"
                                     GroupName="ViewToggle"
                                     IsChecked="{Binding ShowBracket, Mode=TwoWay}"/>
                    </StackPanel>

                    <!-- MATCHES VIEW (Visible when ShowBracket is false) -->
                    <Grid Visibility="{Binding ShowBracket, Converter={StaticResource InvBoolVis}}">
                        <DockPanel Visibility="{Binding IsFinished, Converter={StaticResource InvBoolVis}}">
                            <!-- Column headers -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <!-- P1 name | WIN | vs | WIN | P2 name | gap | Rounds | gap | Char1 | gap | Char2 -->
                                    <ColumnDefinition Width="1.5*"  MinWidth="100"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="1.5*"  MinWidth="100"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="1.2*"  MinWidth="110"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="1.2*"  MinWidth="110"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="PLAYER 1"
                                           Style="{StaticResource ColHeader}"
                                           HorizontalAlignment="Right" Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="4" Text="PLAYER 2"
                                           Style="{StaticResource ColHeader}"
                                           HorizontalAlignment="Left"  Margin="6,0,0,0"/>
                                <TextBlock Grid.Column="6" Text="ROUNDS"
                                           Style="{StaticResource ColHeader}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="8" Text="CHARACTER 1"
                                           Style="{StaticResource ColHeader}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="10" Text="CHARACTER 2"
                                           Style="{StaticResource ColHeader}"
                                           HorizontalAlignment="Center"/>
                            </Grid>

                            <Separator DockPanel.Dock="Top" Margin="0,0,0,6"/>

                            <!-- Match rows -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CurrentMatches}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:MatchRowViewModel}">
                                            <Border Margin="0,0,0,4"
                                                    Padding="0,8"
                                                    BorderThickness="0,0,0,1"
                                                    BorderBrush="{DynamicResource BrushBorder}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.5*"  MinWidth="100"/>
                                                        <ColumnDefinition Width="54"/>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="54"/>
                                                        <ColumnDefinition Width="1.5*"  MinWidth="100"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="1.2*"  MinWidth="110"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="1.2*"  MinWidth="110"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- P1 name -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Player1Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,6,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Player1Name}"/>

                                                    <!-- P1 WIN -->
                                                    <RadioButton Grid.Column="1"
                                                                 Content="WIN"
                                                                 Style="{StaticResource RadioWin}"
                                                                 GroupName="{Binding MatchId}"
                                                                 IsChecked="{Binding Player1Won, Mode=TwoWay}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>

                                                    <!-- vs -->
                                                    <TextBlock Grid.Column="2" Text="vs"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrushTextDim}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>

                                                    <!-- P2 WIN -->
                                                    <RadioButton Grid.Column="3"
                                                                 Content="WIN"
                                                                 Style="{StaticResource RadioWin}"
                                                                 GroupName="{Binding MatchId}"
                                                                 IsChecked="{Binding Player2Won, Mode=TwoWay}"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>

                                                    <!-- P2 name -->
                                                    <TextBlock Grid.Column="4"
                                                               Text="{Binding Player2Name}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               HorizontalAlignment="Left"
                                                               VerticalAlignment="Center"
                                                               Margin="6,0,0,0"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding Player2Name}"/>

                                                    <!-- Rounds -->
                                                    <ComboBox Grid.Column="6"
                                                              ItemsSource="{Binding AvailableRounds}"
                                                              SelectedItem="{Binding Rounds, Mode=TwoWay}"
                                                              IsEnabled="{Binding CanEditRounds}"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalAlignment="Center"/>

                                                    <!-- Char 1 -->
                                                    <ComboBox Grid.Column="8"
                                                              IsEditable="True"
                                                              ItemsSource="{Binding AvailableCharacters}"
                                                              Text="{Binding Character1, Mode=TwoWay,
                                                                     UpdateSourceTrigger=PropertyChanged}"
                                                              ToolTip="{Binding Player1Name}"
                                                              VerticalAlignment="Center"/>

                                                    <!-- Char 2 -->
                                                    <ComboBox Grid.Column="10"
                                                              IsEditable="True"
                                                              ItemsSource="{Binding AvailableCharacters}"
                                                              Text="{Binding Character2, Mode=TwoWay,
                                                                     UpdateSourceTrigger=PropertyChanged}"
                                                              ToolTip="{Binding Player2Name}"
                                                              VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>

                        <!-- Winner Celebration Card (Visible when tournament is finished) -->
                        <Border Visibility="{Binding IsFinished, Converter={StaticResource BoolVis}}"
                                Background="{DynamicResource BrushSurface}"
                                BorderBrush="{DynamicResource BrushAccent}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="40,30"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="500">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="👑"
                                           FontSize="50"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>
                                <TextBlock Text="THE CHAMPION HAS BEEN CROWNED!"
                                           FontSize="18"
                                           FontWeight="ExtraBold"
                                           Foreground="{DynamicResource BrushAccent}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,10"
                                           TextAlignment="Center"/>
                                <TextBlock Text="{Binding WinnerName, StringFormat='Congratulations, {0}! 🏆'}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushText}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"
                                           TextAlignment="Center"/>
                                <TextBlock Text="You have conquered the tournament bracket and claimed ultimate victory!"
                                           FontSize="11"
                                           Foreground="{DynamicResource BrushTextDim}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- BRACKET VIEW (Visible when ShowBracket is true) -->
                    <Grid Visibility="{Binding ShowBracket, Converter={StaticResource BoolVis}}">
                        <DockPanel>
                            <!-- Export Button Bar for Bracket -->
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CHAMPIONSHIP BRACKET" Style="{StaticResource ColHeader}" VerticalAlignment="Center" Margin="0"/>
                                <Button Grid.Column="1"
                                        Content="📷  Export Bracket PNG"
                                        Style="{StaticResource BtnGhost}"
                                        Padding="10,5"
                                        FontSize="10"
                                        Command="{Binding ExportBracketPngCommand}"
                                        CommandParameter="{Binding ElementName=BracketExportContainer}"/>
                            </Grid>

                            <!-- Horizontal stack of rounds/cycles inside export border inside scroll viewer -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Border x:Name="BracketExportContainer" Background="{DynamicResource BrushBg}" Padding="20,25,20,25" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="TOURNAMENT BRACKET" 
                                                   FontSize="15" 
                                                   FontWeight="Bold" 
                                                   Foreground="{DynamicResource BrushAccent}" 
                                                   HorizontalAlignment="Center" 
                                                   Margin="0,0,0,20"/>

                                        <ItemsControl ItemsSource="{Binding CycleSchedule}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="10,0"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:CycleInfoViewModel}">
                                                    <!-- One Round Column -->
                                                    <StackPanel Margin="15,0" Width="190" VerticalAlignment="Center">
                                                        <Border Background="{DynamicResource BrushSurface}" 
                                                                BorderBrush="{DynamicResource BrushBorder}" 
                                                                BorderThickness="1" 
                                                                CornerRadius="4" 
                                                                Padding="10,8" 
                                                                Margin="0,0,0,15">
                                                            <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <Binding Path="Number" StringFormat="ROUND {0}"/>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </Border>
                                                        
                                                        <!-- Vertically distributed list of matches in this cycle -->
                                                        <ItemsControl ItemsSource="{Binding CycleModel.Matches}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate DataType="{x:Type models:Match}">
                                                                    <StackPanel Margin="0,8">
                                                                        <Border Background="{DynamicResource BrushSurface2}" 
                                                                                BorderBrush="{DynamicResource BrushBorder}" 
                                                                                BorderThickness="1" 
                                                                                CornerRadius="4" 
                                                                                Padding="10,8">
                                                                            <Grid>
                                                                                <Grid.RowDefinitions>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                    <RowDefinition Height="Auto"/>
                                                                                </Grid.RowDefinitions>
                                                                                
                                                                                <!-- Player 1 Row -->
                                                                                <Grid Grid.Row="0" Margin="0,0,0,4">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock x:Name="TxtP1" Text="{Binding Player1.Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                                                                                    <TextBlock x:Name="GlyphP1" Grid.Column="1" Text="✓" Foreground="{DynamicResource BrushWin}" Visibility="Collapsed" FontWeight="Bold"/>
                                                                                </Grid>
                                                                                
                                                                                <!-- Player 2 Row -->
                                                                                <Grid Grid.Row="1">
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    <TextBlock x:Name="TxtP2" Text="{Binding Player2.Name}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushText}"/>
                                                                                    <TextBlock x:Name="GlyphP2" Grid.Column="1" Text="✓" Foreground="{DynamicResource BrushWin}" Visibility="Collapsed" FontWeight="Bold"/>
                                                                                </Grid>
                                                                            </Grid>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <DataTemplate.Triggers>
                                                                        <!-- Dim out BYE slots -->
                                                                        <DataTrigger Binding="{Binding Player1.Name}" Value="BYE">
                                                                            <Setter TargetName="TxtP1" Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                                            <Setter TargetName="TxtP1" Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Player2.Name}" Value="BYE">
                                                                            <Setter TargetName="TxtP2" Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                                            <Setter TargetName="TxtP2" Property="FontStyle" Value="Italic"/>
                                                                        </DataTrigger>
                                                                        
                                                                        <!-- Winner 1 highlights -->
                                                                        <DataTrigger Binding="{Binding WinnerId}" Value="1">
                                                                            <Setter TargetName="TxtP1" Property="Foreground" Value="{DynamicResource BrushWin}"/>
                                                                            <Setter TargetName="TxtP2" Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                                            <Setter TargetName="GlyphP1" Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <!-- Winner 2 highlights -->
                                                                        <DataTrigger Binding="{Binding WinnerId}" Value="2">
                                                                            <Setter TargetName="TxtP2" Property="Foreground" Value="{DynamicResource BrushWin}"/>
                                                                            <Setter TargetName="TxtP1" Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                                            <Setter TargetName="GlyphP2" Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </DataTemplate.Triggers>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </ScrollViewer>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource BrushBorder}" ShowsPreview="True"/>

            <!-- ── RIGHT: Standings ───────────────────────────────── -->
            <Border Grid.Column="4"
                    Background="{DynamicResource BrushSurface}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1,0,0,0"
                    Padding="14,18">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="STANDINGS" Style="{StaticResource ColHeader}" Margin="0" VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="📷  Export PNG"
                                Style="{StaticResource BtnGhost}"
                                Padding="8,4"
                                FontSize="9"
                                VerticalAlignment="Center"
                                Command="{Binding ExportStandingsPngCommand}"
                                CommandParameter="{Binding ElementName=StandingsExportContainer}"/>
                    </Grid>

                    <!-- Add Player Mid-Tournament Panel -->
                    <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0" Visibility="{Binding CanAddPlayerMidTournament, Converter={StaticResource BoolVis}}">
                        <Button Content="+  ADD PLAYER MID-TOURNAMENT"
                                FontSize="11"
                                Padding="0,9"
                                Command="{Binding ShowAddPlayerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource BtnGhost}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAddingPlayer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- State 2: Active input form -->
                        <Border Background="{DynamicResource BrushSurface2}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAddingPlayer}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="ADD PLAYER TO TOURNAMENT"
                                           FontSize="9"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrushTextDim}"
                                           Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Text="{Binding NewPlayerName, UpdateSourceTrigger=PropertyChanged}"
                                             Grid.Column="0"
                                             Margin="0,0,6,0"
                                             VerticalAlignment="Center"/>
                                    <Button Grid.Column="1"
                                            Content="Save"
                                            Style="{StaticResource BtnPrimary}"
                                            Padding="10,5"
                                            FontSize="11"
                                            Margin="0,0,4,0"
                                            Command="{Binding SaveNewPlayerCommand}"
                                            VerticalAlignment="Center"/>
                                    <Button Grid.Column="2"
                                            Content="Cancel"
                                            Style="{StaticResource BtnGhost}"
                                            Padding="8,5"
                                            FontSize="11"
                                            Command="{Binding CancelAddPlayerCommand}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Player rows ScrollViewer wrapping isolated Export Container -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Border x:Name="StandingsExportContainer" Background="{DynamicResource BrushSurface}" Padding="10,15,10,15" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="TOURNAMENT LEADERBOARD"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrushAccent}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15"/>

                                <!-- Header row -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>   <!-- # -->
                                        <ColumnDefinition Width="1.2*"/> <!-- name -->
                                        <ColumnDefinition Width="26"/>   <!-- W -->
                                        <ColumnDefinition Width="26"/>   <!-- L -->
                                        <ColumnDefinition Width="44"/>   <!-- WR% -->
                                        <ColumnDefinition Width="*"/>    <!-- CHAR -->
                                        <ColumnDefinition Width="22"/>   <!-- ✕ -->
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="#"    Style="{StaticResource ColHeader}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="NAME" Style="{StaticResource ColHeader}"/>
                                    <TextBlock Grid.Column="2" Text="W"    Style="{StaticResource ColHeader}" HorizontalAlignment="Center" Foreground="{DynamicResource BrushWin}"/>
                                    <TextBlock Grid.Column="3" Text="L"    Style="{StaticResource ColHeader}" HorizontalAlignment="Center" Foreground="{DynamicResource BrushLoss}"/>
                                    <TextBlock Grid.Column="4" Text="WR%"  Style="{StaticResource ColHeader}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="CHAR" Style="{StaticResource ColHeader}" HorizontalAlignment="Center"/>
                                </Grid>
                                <Separator Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding Standings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:PlayerStatsViewModel}">
                                            <Border MinHeight="28" Padding="0,2" CornerRadius="3" Margin="0,1">
                                                <!-- Eliminated tint -->
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEliminated}" Value="True">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource BrushElim}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="22"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="26"/>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="22"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Rank -->
                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}"
                                                               Style="{StaticResource StatCell}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource BrushTextDim}"/>

                                                    <!-- Name -->
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               FontSize="12"
                                                               Padding="2,0"
                                                               ToolTip="{Binding Name}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource StatName}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsEliminated}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource BrushTextDim}"/>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- W -->
                                                    <TextBlock Grid.Column="2" Text="{Binding Wins}"
                                                               Style="{StaticResource StatCell}"
                                                               Foreground="{DynamicResource BrushWin}"/>

                                                    <!-- L -->
                                                    <TextBlock Grid.Column="3" Text="{Binding Losses}"
                                                               Style="{StaticResource StatCell}"
                                                               Foreground="{DynamicResource BrushLoss}"/>

                                                    <!-- WR% -->
                                                    <TextBlock Grid.Column="4" Text="{Binding WinRate}"
                                                               Style="{StaticResource StatCell}"
                                                               FontSize="11"/>

                                                    <!-- Most Picked -->
                                                    <TextBlock Grid.Column="5" Text="{Binding MostPicked}"
                                                               Style="{StaticResource StatCell}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrushTextDim}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding MostPicked}"/>

                                                    <!-- Eliminate button -->
                                                    <Button Grid.Column="6"
                                                            Style="{StaticResource BtnElim}"
                                                            Command="{Binding EliminateCommand}"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Visibility="{Binding IsEliminated,
                                                                         Converter={StaticResource InvBoolVis}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
